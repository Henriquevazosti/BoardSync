              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/lists/board/{{board_id}}"
          }
        },
        {
          "name": "Get List By Id",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/lists/{{list_id}}"
          }
        },
        {
          "name": "Create List",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nova Lista\",\n  \"color\": \"#FF9800\"\n}"
            },
            "url": "{{base_url}}/lists/board/{{board_id}}"
          }
        },
        {
          "name": "Update List",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Lista Atualizada\",\n  \"position\": 1\n}"
            },
            "url": "{{base_url}}/lists/{{list_id}}"
          }
        },
        {
          "name": "Delete List",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/lists/{{list_id}}"
          }
        }
      ]
    },
    {
      "name": "Cards",
      "item": [
        {
          "name": "List Cards By List",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const response = pm.response.json();",
                  "  const cards = response.data || response.cards || response || [];",
                  "  if (Array.isArray(cards) && cards.length > 0 && cards[0].id) pm.environment.set('card_id', cards[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/cards/list/{{list_id}}?page=1&limit=50"
          }
        },
        {
          "name": "Get Card By Id",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/cards/{{card_id}}"
          }
        },
        {
          "name": "Create Card",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Novo Card\",\n  \"description\": \"Criado via Postman\",\n  \"priority\": \"media\",\n  \"category\": \"tarefa\"\n}"
            },
            "url": "{{base_url}}/cards/list/{{list_id}}"
          }
        },
        {
          "name": "Update Card",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Card Atualizado\",\n  \"description\": \"Atualizado via Postman\",\n  \"priority\": \"alta\"\n}"
            },
            "url": "{{base_url}}/cards/{{card_id}}"
          }
        },
        {
          "name": "Move Card",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"new_list_id\": \"{{list_id}}\",\n  \"new_position\": 1\n}"
            },
            "url": "{{base_url}}/cards/{{card_id}}/move"
          }
        },
        {
          "name": "Assign Users To Card",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_ids\": [\n    \"{{user_id}}\"\n  ]\n}"
            },
            "url": "{{base_url}}/cards/{{card_id}}/assign"
          }
        },
        {
          "name": "Delete Card",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/cards/{{card_id}}"
          }
        }
      ]
    },
