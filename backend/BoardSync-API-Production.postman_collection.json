{
  "info": {
    "name": "BoardSync API - Production",
    "description": "Collection do Postman para a API do BoardSync em produção, com todas as rotas atualmente expostas pelo backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "base_url", "value": "https://boardsync.onrender.com/api/v1", "type": "string" },
    { "key": "auth_token", "value": "", "type": "string" },
    { "key": "workspace_id", "value": "", "type": "string" },
    { "key": "board_id", "value": "", "type": "string" },
    { "key": "list_id", "value": "", "type": "string" },
    { "key": "card_id", "value": "", "type": "string" },
    { "key": "label_id", "value": "", "type": "string" },
    { "key": "comment_id", "value": "", "type": "string" },
    { "key": "user_id", "value": "", "type": "string" },
    { "key": "email", "value": "admin@boardsync.com", "type": "string" },
    { "key": "password", "value": "123456", "type": "string" }
  ],
  "item": [
    {
      "name": "Base",
      "item": [
        {
          "name": "Health",
          "auth": { "type": "noauth" },
          "request": {
            "method": "GET",
            "url": "https://boardsync.onrender.com/health",
            "description": "Verifica se a API está online."
          }
        },
        {
          "name": "Root",
          "auth": { "type": "noauth" },
          "request": {
            "method": "GET",
            "url": "https://boardsync.onrender.com/",
            "description": "Informações básicas da API."
          }
        },
        {
          "name": "API Root",
          "auth": { "type": "noauth" },
          "request": {
            "method": "GET",
            "url": "{{base_url}}",
            "description": "Informações da versão v1 da API."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "auth": { "type": "noauth" },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const response = pm.response.json();",
                  "  if (response.token) pm.environment.set('auth_token', response.token);",
                  "  if (response.user && response.user.id) pm.environment.set('user_id', response.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Novo Usuario\",\n  \"email\": \"novo.usuario@boardsync.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": "{{base_url}}/auth/register"
          }
        },
        {
          "name": "Login",
          "auth": { "type": "noauth" },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const response = pm.response.json();",
                  "  if (response.token) pm.environment.set('auth_token', response.token);",
                  "  if (response.user && response.user.id) pm.environment.set('user_id', response.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          }
        },
        {
          "name": "Forgot Password",
          "auth": { "type": "noauth" },
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\"\n}"
            },
            "url": "{{base_url}}/auth/forgot-password"
          }
        },
        {
          "name": "Reset Password",
          "auth": { "type": "noauth" },
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"newPassword\": \"123456\",\n  \"resetToken\": \"COLOQUE_O_TOKEN_AQUI\"\n}"
            },
            "url": "{{base_url}}/auth/reset-password"
          }
        },
        {
          "name": "Verify Token",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/verify"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const response = pm.response.json();",
                  "  const users = response.data || response.users || [];",
                  "  if (users.length > 0 && users[0].id) pm.environment.set('user_id', users[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users"
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Administrador BoardSync\"\n}"
            },
            "url": "{{base_url}}/users/profile"
          }
        }
      ]
    },
    {
      "name": "Workspaces",
      "item": [
        {
          "name": "List Workspaces",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const response = pm.response.json();",
                  "  const workspaces = response.data || response.workspaces || response || [];",
                  "  if (Array.isArray(workspaces) && workspaces.length > 0 && workspaces[0].id) pm.environment.set('workspace_id', workspaces[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/workspaces"
          }
        },
        {
          "name": "Get Workspace By Id",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/workspaces/{{workspace_id}}"
          }
        },
        {
          "name": "Create Workspace",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Workspace Producao\",\n  \"description\": \"Criado via Postman\",\n  \"color\": \"#4CAF50\",\n  \"visibility\": \"private\"\n}"
            },
            "url": "{{base_url}}/workspaces"
          }
        },
        {
          "name": "Update Workspace",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Workspace Atualizado\",\n  \"description\": \"Atualizado via Postman\"\n}"
            },
            "url": "{{base_url}}/workspaces/{{workspace_id}}"
          }
        },
        {
          "name": "Add Member",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"membro@boardsync.com\",\n  \"role\": \"member\"\n}"
            },
            "url": "{{base_url}}/workspaces/{{workspace_id}}/members"
          }
        },
        {
          "name": "Remove Member",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/workspaces/{{workspace_id}}/members/{{user_id}}"
          }
        },
        {
          "name": "Delete Workspace",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/workspaces/{{workspace_id}}"
          }
        }
      ]
    },
    {
      "name": "Boards",
      "item": [
        {
          "name": "List Boards By Workspace",
          "event": [
            {
              "listen": "test",
