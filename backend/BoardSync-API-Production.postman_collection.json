            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Board Atualizado\",\n  \"description\": \"Atualizado via Postman\"\n}"
            },
            "url": "{{base_url}}/boards/{{board_id}}"
          }
        },
        {
          "name": "Delete Board",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/boards/{{board_id}}"
          }
        }
      ]
    },
    {
      "name": "Lists",
      "item": [
        {
          "name": "List Lists By Board",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
