          "request": {
            "method": "GET",
            "url": "{{base_url}}/boards/{{board_id}}"
          }
        },
        {
          "name": "Create Board",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Board Producao\",\n  \"description\": \"Criado via Postman\",\n  \"background_color\": \"#0052CC\"\n}"
            },
            "url": "{{base_url}}/boards/workspace/{{workspace_id}}"
          }
        },
        {
          "name": "Update Board",
